# ---- MongoDB (local mongod; no Docker) ----
# The normalized event store + all collections live here.
MONGODB_URI=mongodb://localhost:27017/shiplog-sync

# Separate database used by the test suite (dropped on each run).
MONGODB_TEST_URI=mongodb://localhost:27017/shiplog-sync-test

# ---- HTTP server ----
PORT=3000

# ---- Redis (Milestone 2+: BullMQ queues, retries, DLQ) — not required for M0/M1 ----
# REDIS_URL=redis://localhost:6379

# ---- Nango (Milestone 4+: real GitHub integration) — not required for M0/M1 ----
# NANGO_SECRET_KEY=
# NANGO_WEBHOOK_SECRET=
