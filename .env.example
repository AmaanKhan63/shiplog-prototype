# ---- MongoDB (local mongod; no Docker) ----
# The normalized event store + all collections live here.
MONGODB_URI=mongodb://localhost:27017/shiplog-sync

# Separate database used by the test suite (dropped on each run).
MONGODB_TEST_URI=mongodb://localhost:27017/shiplog-sync-test

# ---- HTTP server ----
PORT=3000

# ---- Redis (Milestone 2+: BullMQ queues, retries, DLQ) ----
# Local:   redis://localhost:6379
# Upstash: rediss://default:<password>@<host>.upstash.io:6379  (TLS auto-enabled by the rediss:// scheme)
REDIS_URL=redis://localhost:6379

# ---- Nango (Milestone 4: real GitHub integration) ----
# Backend secret key (Nango dashboard > Environment Settings). Drives the records API.
# NANGO_SECRET_KEY=
# Webhook signing key (Nango dashboard > Environment Settings > Webhooks > Signing key).
# Used to verify X-Nango-Hmac-Sha256 on incoming webhooks. SEPARATE from the secret key.
# NANGO_WEBHOOK_SECRET=
# NANGO_HOST=https://api.nango.dev
# Set true (or leave NANGO_SECRET_KEY empty) to serve static fixtures instead of
# calling real Nango — lets you exercise the full pipeline locally without an account.
NANGO_USE_FIXTURES=true
