{
  "name": "shiplog-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "One-directional ingestion + resilience layer for Shiplog, built on top of Nango (MERN). Milestones 0-1: scaffold + idempotent normalized event spine.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "verify": "node scripts/seed-and-verify.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  }
}
